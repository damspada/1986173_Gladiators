# Backend container image supplied by teammate branch/repository
BACKEND_IMAGE=your-team/backend:latest

# Host ports
FRONTEND_PORT=5173
BACKEND_PORT=8090
SIMULATOR_PORT=8080

# Frontend build-time endpoints. Relative paths are strongly suggested
# so Nginx can route everything to BACKEND_UPSTREAM.
VITE_LIVE_WS_URL=/api/events/ws
VITE_HISTORY_API_URL=/api/history/events

# Frontend runtime upstream inside Docker network
BACKEND_UPSTREAM=backend:8080

# Backend to simulator integration
SIMULATOR_BASE_URL=http://simulator:8080

# Simulator controls (per assignment contracts)
SAMPLING_RATE_HZ=20
AUTO_SHUTDOWN_ENABLED=true
AUTO_SHUTDOWN_MIN_SECONDS=30
AUTO_SHUTDOWN_MAX_SECONDS=90
